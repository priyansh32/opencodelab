# Optional absolute base URL. Leave empty to use same-origin paths.
# Example: https://executor.example.com
VITE_EXECUTOR_BASE_URL=

# API version header for /producer requests.
VITE_ACCEPT_VERSION=1

# Frontend-side guardrail to match backend MAX_CODE_LENGTH.
VITE_MAX_CODE_LENGTH=10000

# Dev server proxy target used by vite.config.ts.
VITE_PROXY_TARGET=http://localhost
